{
  "name": "MyMacCleaner",
  "version": "0.1.5",
  "description": "Open-source CleanMyMac-style cleanup utility for macOS. Conservative-by-default — everything goes to Trash.",
  "author": "Tarun (https://github.com/gtarun)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtarun/MyMacCleaner.git"
  },
  "homepage": "https://github.com/gtarun/MyMacCleaner#readme",
  "bugs": {
    "url": "https://github.com/gtarun/MyMacCleaner/issues"
  },
  "keywords": [
    "macos",
    "electron",
    "disk-cleanup",
    "duplicate-finder",
    "uninstaller",
    "mac-cleaner"
  ],
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c \"yellow,cyan\" \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build",
    "build:icon": "node scripts/build-icon.js",
    "build": "npm run build:renderer",
    "pack": "npm run build:renderer && electron-builder --dir",
    "dist": "npm run build:renderer && electron-builder",
    "dist:ci": "npm run build:renderer && electron-builder --publish never",
    "bump": "node scripts/bump.js",
    "bump:patch": "node scripts/bump.js patch",
    "bump:minor": "node scripts/bump.js minor",
    "bump:major": "node scripts/bump.js major",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "release:build": "npm run build:icon && npm run dist:ci",
    "start": "electron ."
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "sharp": "^0.33.5",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "net.chatbotbuilder.MacCleaner",
    "productName": "MacCleaner",
    "publish": null,
    "copyright": "© ${author}",
    "directories": {
      "buildResources": "build",
      "output": "dist-electron"
    },
    "files": [
      "src/main/**/*",
      "src/preload.js",
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "NSHumanReadableCopyright": "Copyright © Tarun. Licensed under the MIT License.",
        "LSApplicationCategoryType": "public.app-category.utilities",
        "NSDocumentsFolderUsageDescription": "MacCleaner scans your Documents folder for large or stale files.",
        "NSDesktopFolderUsageDescription": "MacCleaner scans your Desktop for large or stale files.",
        "NSDownloadsFolderUsageDescription": "MacCleaner scans your Downloads folder for large or stale files."
      }
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "build/icon.icns",
      "contents": [
        {
          "x": 140,
          "y": 200
        },
        {
          "x": 420,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 560,
        "height": 400
      }
    }
  }
}
